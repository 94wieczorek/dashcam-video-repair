<Window x:Class="DashcamVideoRepair.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DashcamVideoRepair"
        xmlns:models="clr-namespace:DashcamVideoRepair.Models"
        Title="Naprawa wideo z kamerki samochodowej"
        Height="550" Width="700"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragOver="DropZone_DragOver"
        Drop="DropZone_Drop"
        Background="#1E1E1E">
    <Window.Resources>
        <local:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <local:StatusToVisibilityConverter x:Key="StatusToVisibilityConverter"/>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,0"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- DropZone -->
        <Border Grid.Row="0"
                x:Name="DropZoneBorder"
                Background="#2D2D2D"
                BorderBrush="#555555"
                BorderThickness="2"
                CornerRadius="6"
                Padding="20"
                AllowDrop="True"
                IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"
                DragOver="DropZone_DragOver"
                Drop="DropZone_Drop"
                MinHeight="80">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="Przeciągnij pliki wideo lub foldery tutaj"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="16"
                       Foreground="#888888"/>
        </Border>

        <!-- File List -->
        <ListView Grid.Row="2"
                  ItemsSource="{Binding RepairQueue}"
                  Background="#252525"
                  BorderBrush="#555555"
                  Foreground="#E0E0E0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="4,6"/>
                    <Setter Property="BorderBrush" Value="#333333"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status indicator -->
                        <Ellipse Grid.Column="0"
                                 Width="12" Height="12"
                                 VerticalAlignment="Center"
                                 Fill="{Binding Status, Converter={StaticResource StatusToColorConverter}}"/>

                        <!-- Filename with error tooltip -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding FileName}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,8,0"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="#E0E0E0">
                            <TextBlock.ToolTip>
                                <ToolTip Content="{Binding ErrorMessage}"
                                         Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                            </TextBlock.ToolTip>
                        </TextBlock>

                        <!-- Progress bar (visible during Processing) -->
                        <ProgressBar Grid.Column="2"
                                     Value="{Binding Progress}"
                                     Minimum="0" Maximum="100"
                                     Height="14"
                                     VerticalAlignment="Center"
                                     Background="#333333"
                                     Foreground="#4CAF50"
                                     BorderBrush="#555555"
                                     Visibility="{Binding Status, Converter={StaticResource StatusToVisibilityConverter}}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Warning message -->
        <TextBlock Grid.Row="4"
                   Text="{Binding WarningMessage}"
                   Foreground="#FFA726"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Visibility="{Binding WarningMessage, Converter={StaticResource NullToVisibilityConverter}}"/>


        <!-- Batch summary -->
        <TextBlock Grid.Row="6"
                   Text="{Binding BatchSummary}"
                   Foreground="#81C784"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Visibility="{Binding BatchSummary, Converter={StaticResource NullToVisibilityConverter}}"/>


        <!-- Button bar -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Wybierz pliki"
                    Command="{Binding SelectFilesCommand}"
                    Style="{StaticResource ActionButton}"/>
            <Button Content="Rozpocznij naprawę"
                    Command="{Binding StartRepairCommand}"
                    Style="{StaticResource ActionButton}"/>
            <Button Content="Otwórz folder wyjściowy"
                    Command="{Binding OpenOutputFolderCommand}"
                    Style="{StaticResource ActionButton}"/>
            <Button Content="Ustawienia"
                    Command="{Binding OpenSettingsCommand}"
                    Style="{StaticResource ActionButton}"/>
        </StackPanel>
    </Grid>
</Window>
